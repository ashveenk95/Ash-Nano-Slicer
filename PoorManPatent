        "import json\n",
        "\n",
        "class NanoRouter:\n",
        "    def __init__(self):\n",
        "        self.design = {\"component\": \"ROUTED_CHIP\", \"layers\": []}\n",
        "        self.metal_layer = {\"material\": \"copper_interconnect\", \"paths\": []}\n",
        "\n",
        "    def add_gate(self, gate_json):\n",
        "        self.design[\"layers\"].extend(gate_json[\"layers\"])\n",
        "\n",
        "    def auto_connect(self, point1, point2):\n",
        "        \"\"\"\n",
        "        Calculates a 'Manhattan' path between two points automatically.\n",
        "        point1: (x, y), point2: (x, y)\n",
        "        \"\"\"\n",
        "        x1, y1 = point1\n",
        "        x2, y2 = point2\n",
        "\n",
        "        # Draw Horizontal segment\n",
        "        self.metal_layer[\"paths\"].append([x1, y1, x2, y1])\n",
        "        # Draw Vertical segment\n",
        "        self.metal_layer[\"paths\"].append([x2, y1, x2, y2])\n",
        "\n",
        "    def finalize(self):\n",
        "        self.design[\"layers\"].append(self.metal_layer)\n",
        "        return self.design\n",
        "\n",
        "# --- ACTION: CONNECTING TWO GATES ---\n",
        "router = NanoRouter()\n",
        "\n",
        "# Let's say Gate 1 Output is at (20, 5) and Gate 2 Input is at (35, 2)\n",
        "router.auto_connect((20, 5), (35, 2))\n",
        "\n",
        "print(json.dumps(router.finalize(), indent=4))"
