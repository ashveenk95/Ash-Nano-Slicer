        "# A tool to 'draw' a NAND gate using multiple laser streams.\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as patches\n",
        "\n",
        "# 1. THE DATA: The 'map' of the NAND gate on the wafer\n",
        "design_data = {\n",
        "    'transistor_p_well': [(0, 10, 20, 10)], # [x, y, width, height]\n",
        "    'transistor_n_well': [(0, 0, 20, 10)],\n",
        "    'gate_poly_A': [(5, -2, 2, 14)], # Laser Head 1 Path\n",
        "    'gate_poly_B': [(13, -2, 2, 14)], # Laser Head 2 Path\n",
        "    'metal_vdd': [(0, 15, 20, 3)],  # Laser Head 3 Path\n",
        "    'metal_gnd': [(0, -2, 20, 3)],  # Laser Head 4 Path\n",
        "    'metal_output': [(18, 5, 2, 30)]\n",
        "}\n",
        "\n",
        "# 2. THE VISUALIZER: A placeholder for the 'G-Code' we discussed.\n",
        "# This actually shows where the lasers will fire.\n",
        "\n",
        "def visualize_nanoprint(design, grid_size=30):\n",
        "    fig, ax = plt.subplots(figsize=(8, 6))\n",
        "    ax.set_xlim(-5, grid_size)\n",
        "    ax.set_ylim(-5, grid_size)\n",
        "    ax.set_aspect('equal')\n",
        "    ax.set_title('Visualization: Your Multi-Laser NAND Gate \"Nano-Print\"')\n",
        "\n",
        "    # Layer colors (simulating materials like Poly, Copper Sulphide, Germanium)\n",
        "    colors = {'well': 'lightgray', 'poly': 'red', 'metal': 'blue'}\n",
        "\n",
        "    # Placeholder for the parallel streams\n",
        "    laser_streams = [\n",
        "        ('gate_poly_A', 'poly', 'Head 1 (A)'), # Changed 'red' to 'poly'\n",
        "        ('gate_poly_B', 'poly', 'Head 2 (B)'), # Changed 'red' to 'poly'\n",
        "        ('metal_vdd', 'metal', 'Head 3 (Vdd)'), # Changed 'blue' to 'metal'\n",
        "        ('metal_gnd', 'metal', 'Head 4 (Gnd)'), # Changed 'blue' to 'metal'\n",
        "    ]\n",
        "\n",
        "    # Draw the underlying architecture\n",
        "    for r in design['transistor_p_well']:\n",
        "        ax.add_patch(patches.Rectangle((r[0], r[1]), r[2], r[3], color=colors['well'], alpha=0.3, label='p-Well'))\n",
        "    for r in design['transistor_n_well']:\n",
        "        ax.add_patch(patches.Rectangle((r[0], r[1]), r[2], r[3], color=colors['well'], alpha=0.3))\n",
        "\n",
        "    # Draw the active, synchronized 'Laser Strikes' (the parallel 'G-Code')\n",
        "    for design_key, color_key, label in laser_streams:\n",
        "        for r in design[design_key]:\n",
        "            # This is where the hardware actually 'etches' the material\n",
        "            ax.add_patch(patches.Rectangle((r[0], r[1]), r[2], r[3], color=colors[color_key], label=label, edgecolor='black'))\n",
        "\n",
        "    # The final output trace (Metal 1)\n",
        "    for r in design['metal_output']:\n",
        "        ax.add_patch(patches.Rectangle((r[0], r[1]), r[2], r[3], color='green', label='Output Trace', linestyle='--'))\n",
        "\n",
        "    ax.legend(loc='upper right', fontsize='small')\n",
        "    plt.grid(True, linestyle='--', alpha=0.5)\n",
        "    plt.show()\n",
        "\n",
