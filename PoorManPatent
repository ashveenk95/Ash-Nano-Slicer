        "import time\n",
        "\n",
        "class LaserSlicer:\n",
        "    def __init__(self, ip_address=\"192.168.1.100\"):\n",
        "        self.ip = ip_address\n",
        "        self.feed_rate = 100 # mm/min\n",
        "\n",
        "    def slice_layer(self, layer_data):\n",
        "        \"\"\"Converts JSON design into a live command stream.\"\"\"\n",
        "        print(f\"--- Slicing Material: {layer_data['material']} ---\")\n",
        "        gcode_stream = []\n",
        "        for path in layer_data['paths']:\n",
        "            x1, y1, x2, y2 = path\n",
        "            # Rapid to Start, Laser ON, Move, Laser OFF\n",
        "            gcode_stream.append(f\"G0 X{x1} Y{y1}\")\n",
        "            gcode_stream.append(f\"M3 S255 ; Laser High Power\")\n",
        "            gcode_stream.append(f\"G1 X{x2} Y{y2} F{self.feed_rate}\")\n",
        "            gcode_stream.append(\"M5 ; Laser OFF\")\n",
        "        return gcode_stream\n",
        "\n",
        "    def send_to_esp32(self, commands):\n",
        "        \"\"\"Simulates sending G-code to a Grbl_ESP32 controller over Wi-Fi.\"\"\"\n",
        "        print(f\"Connecting to ESP32 at {self.ip}...\")\n",
        "        for cmd in commands:\n",
        "            # In real life: requests.post(f\"http://{self.ip}/gcode?cmd={cmd}\")\n",
        "            print(f\"[SENDING]: {cmd}\")\n",
        "            time.sleep(0.05) # Simulate hardware latency\n",
        "        print(\"Layer Complete.\")\n",
        "\n",
        "# --- LIVE TEST ---\n",
        "slicer = LaserSlicer()\n",
        "design = {\"material\": \"Polysilicon\", \"paths\": [[10, 10, 10, 25], [20, 10, 20, 25]]}\n",
        "slicer.send_to_esp32(slicer.slice_layer(design))"
