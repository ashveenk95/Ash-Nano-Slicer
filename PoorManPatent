        "import json\n",
        "\n",
        "class NanoEDA:\n",
        "    def __init__(self, trace_width=2, spacing=8):\n",
        "        self.trace_width = trace_width\n",
        "        self.spacing = spacing\n",
        "        self.design = {\"component\": \"AUTO_GEN\", \"layers\": []}\n",
        "\n",
        "    def create_nand(self, start_x=0, start_y=0):\n",
        "        # The 'Physical Recipe' for a NAND Gate\n",
        "        # Layer 1: The 'Input' Gate Traces (Polysilicon)\n",
        "        poly_layer = {\n",
        "            \"material\": \"polysilicon\",\n",
        "            \"paths\": [\n",
        "                [start_x + 5, start_y - 2, start_x + 5, start_y + 12], # Input A\n",
        "                [start_x + 13, start_y - 2, start_x + 13, start_y + 12] # Input B\n",
        "            ]\n",
        "        }\n",
        "\n",
        "        # Layer 2: The 'Power' Rails (Copper Sulphide)\n",
        "        copper_layer = {\n",
        "            \"material\": \"copper_sulphide\",\n",
        "            \"paths\": [\n",
        "                [start_x, start_y + 15, start_x + 20, start_y + 15], # VDD\n",
        "                [start_x, start_y - 2, start_x + 20, start_y - 2]   # GND\n",
        "            ]\n",
        "        }\n",
        "\n",
        "        self.design[\"layers\"].extend([poly_layer, copper_layer])\n",
        "        return self.design\n",
        "\n",
        "# --- ACTION ---\n",
        "eda = NanoEDA()\n",
        "# Let's 'place' two NAND gates side-by-side\n",
        "eda.create_nand(start_x=0)\n",
        "eda.create_nand(start_x=30) # Offset by 30mm for the second gate\n",
        "\n",
        "# Save it to a JSON 'Design File'\n",
        "with open('chip_design.json', 'w') as f:\n",
        "    json.dump(eda.design, f, indent=4)\n",
        "\n",
        "print(\"Design File 'chip_design.json' Created!\")"
      ]
