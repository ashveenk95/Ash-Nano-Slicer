        "def simulate_interference(wavelength=0.405, beam_positions=[0, 0.05], grid_size=500):\n",
        "    \"\"\"\n",
        "    Simulates the interference pattern of multiple 405nm laser beams.\n",
        "    wavelength: in micrometers (405nm = 0.405um)\n",
        "    beam_positions: X-coordinates of your laser heads in mm\n",
        "    \"\"\"\n",
        "    x = np.linspace(-0.1, 0.1, grid_size) # 200 micron window\n",
