        "def slice_to_gcode(design):\n",
        "    output = [\"; Nano-Slicer Output\", \"G21 ; mm\", \"G90 ; Absolute\"]\n",
        "\n",
        "    for layer in design['layers']:\n",
        "        output.append(f\"; Starting Layer: {layer['material']}\")\n",
