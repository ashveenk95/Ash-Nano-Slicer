        "class NanoSlicerCore:\n",
        "    def __init__(self, laser_min_power=0, laser_max_power=255):\n",
        "        self.min_p = laser_min_power\n",
        "        self.max_p = laser_max_power\n",
        "        self.gcode = []\n",
        "\n",
        "    def svg_to_nanogcode(self, svg_file, output_file):\n",
        "        # 1. Parse the SVG paths\n",
        "        paths, attributes = svgpathtools.svg2paths(svg_file)\n",
        "\n",
        "        self.gcode.append(\"; --- ASH-NANO-SLICER INITIALIZED ---\")\n",
        "        self.gcode.append(\"G21 ; Millimeters\")\n",
        "        self.gcode.append(\"G90 ; Absolute Positioning\")\n",
        "\n",
        "        for i, (path, attr) in enumerate(zip(paths, attributes)):\n",
        "            # 2. Logic Check: Is this a \"Critical\" or \"Macro\" path?\n",
        "            # We use SVG 'stroke-width' or 'id' to decide\n",
        "            is_critical = \"critical\" in attr.get('id', '').lower()\n",
        "            power = self.max_p if is_critical else 150 # Lower power for bulk\n",
        "            feed = 50 if is_critical else 500         # Slower for critical lines\n",
        "\n",
        "            self.gcode.append(f\"; Path {i}: {attr.get('id', 'unnamed')}\")\n",
        "\n",
        "            # 3. Convert SVG Curves to G-Code Segments\n",
        "            for segment in path:\n",
        "                start = segment.start\n",
        "                end = segment.end\n",
        "\n",
        "                # Move to Start (Laser OFF)\n",
        "                self.gcode.append(f\"G0 X{round(start.real, 4)} Y{round(start.imag, 4)} M5\")\n",
        "                # Etch to End (Laser ON)\n",
        "                self.gcode.append(f\"G1 X{round(end.real, 4)} Y{round(end.imag, 4)} S{power} F{feed} M3\")\n",
        "\n",
        "        # 4. Save to File\n",
        "        with open(output_file, 'w') as f:\n",
        "            f.write(\"\\n\".join(self.gcode))\n",
        "        print(f\"Successfully sliced {len(paths)} paths to {output_file}\")\n",
