        "    X, Y = np.meshgrid(x, y)\n",
        "\n",
        "    intensity = np.zeros_like(X)\n",
        "    k = 2 * np.pi / wavelength # Wave number\n",
        "\n",
        "    # Simulate electric field superposition\n",
        "    field = np.zeros_like(X, dtype=complex)\n",
        "    for pos in beam_positions:\n",
        "        # Distance from each beam 'source'\n",
        "        r = np.sqrt((X - pos)**2 + Y**2)\n",
        "        field += np.exp(1j * k * r) / (r + 0.01) # Simple wave propagation\n",
        "\n",
        "    intensity = np.abs(field)**2\n",
        "    # Normalize\n",
        "    intensity /= np.max(intensity)\n",
        "\n",
        "    return X, Y, intensity\n",
