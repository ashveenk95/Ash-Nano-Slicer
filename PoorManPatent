        "import json\n",
        "\n",
        "# Your 'Design File' (The equivalent of an STL)\n",
        "nand_design = {\n",
        "    \"component\": \"NAND_GATE_01\",\n",
        "    \"layers\": [\n",
        "        {\"material\": \"polysilicon\", \"paths\": [[5, -2, 5, 12], [13, -2, 13, 12]]},\n",
        "        {\"material\": \"copper_sulphide\", \"paths\": [[0, 15, 20, 15], [0, -2, 20, -2]]}\n",
        "    ]\n",
        "}\n",
        "\n",
        "def slice_to_gcode(design):\n",
        "    output = [\"; Nano-Slicer Output\", \"G21 ; mm\", \"G90 ; Absolute\"]\n",
        "\n",
        "    for layer in design['layers']:\n",
        "        output.append(f\"; Starting Layer: {layer['material']}\")\n",
        "        for path in layer['paths']:\n",
        "            x1, y1, x2, y2 = path\n",
        "            output.append(f\"G0 X{x1} Y{y1} ; Rapid to Start\")\n",
        "            output.append(f\"M3 S255 ; Laser ON\")\n",
        "            output.append(f\"G1 X{x2} Y{y2} F100 ; Etching Path\")\n",
        "            output.append(f\"M5 ; Laser OFF\")\n",
        "\n",
        "    return \"\\n\".join(output)\n",
        "\n",
        "print(slice_to_gcode(nand_design))\n"
      ],
